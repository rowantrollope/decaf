{
  "manifest_version": 3,
  "name": "ChillMode",
  "version": "1.1.0",
  "description": "Rewrites breathless, FOMO-inducing posts on X/Twitter into calm, grounded, informative text.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:11435/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
